# ============================================================
# SaringSini v2.2 Environment Configuration
# ============================================================
# Copy file ini ke .env dan isi nilai sebenarnya
# cp .env.example .env  (Linux/macOS)
# copy .env.example .env  (Windows)
# ============================================================

# --- WAJIB ---

# Google AI Studio API Key (dapatkan gratis di https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# --- OPSIONAL ---

# Port HTTP server (default: 3000)
# Cloud Run akan otomatis mengset PORT env var
PORT=3000

# Mode aplikasi: development | production
# production mengaktifkan: cache headers, error message sanitization,
# dan hide stack traces dari user
NODE_ENV=development
